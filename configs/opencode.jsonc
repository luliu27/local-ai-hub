{
    "$schema": "https://opencode.ai/config.json",
    "plugin": [
        "@tarquinen/opencode-dcp@latest"
    ],
    "provider": {
        "local": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "Local Server",
            "options": {
                "baseURL": "http://127.0.0.1:1235/v1"
            },
            "models": {
                "qwen3.5-2b": {
                    "model": "qwen3.5-2b"
                },
                "qwen3.6-27b": {
                    "model": "qwen3.6-27b"
                },
                "qwen3.6-27b-thinking": {
                    "model": "qwen3.6-27b-thinking"
                },
                "qwen3.6-27b-coding": {
                    "model": "qwen3.6-27b-coding"
                },
                "qwen3.6-35b-a3b-thinking-general": {
                    "model": "qwen3.6-35b-a3b-thinking-general"
                },
                "qwen3.6-35b-a3b-thinking-coding": {
                    "model": "qwen3.6-35b-a3b-thinking-coding"
                },
                "qwen3.6-35b-a3b-instruct-general": {
                    "model": "qwen3.6-35b-a3b-instruct-general"
                },
                "qwen3.6-35b-a3b-instruct-reasoning": {
                    "model": "qwen3.6-35b-a3b-instruct-reasoning"
                },
                "gemma4-31b": {
                    "model": "gemma4-31b"
                },
                "gpt-20b": {
                    "model": "gpt-oss-20b"
                }
            }
        }
    },
    "small_model": "local/qwen3.5-2b"
}